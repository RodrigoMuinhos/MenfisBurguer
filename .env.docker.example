# Copie para .env.local antes de rodar docker compose.

# Backend
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
JWT_SECRET=dev-only-change-me-dev-only-change-me
MENFIS_ENVIRONMENT=local
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_MP_PUBLIC_KEY=
NEXT_PUBLIC_ORDER_RUNTIME_MODE=delivery

# Portas locais
FRONTEND_PORT=3000
BACKEND_PORT=8080

# Mercado Pago, opcional para fluxo local sem pagamento online
MERCADO_PAGO_ACCESS_TOKEN=
MP_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_PAYER_EMAIL=
MERCADO_PAGO_CARD_PAYER_EMAIL=

# WhatsApp Cloud API, opcional para testes locais
WHATSAPP_VERIFY_TOKEN=menfis-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=1217044968149576
WHATSAPP_BUSINESS_ACCOUNT_ID=864066526222050
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v20.0
