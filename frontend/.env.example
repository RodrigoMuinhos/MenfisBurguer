# Copy this file to .env before running Docker Compose
# Use your real Neon/Postgres connection string here
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Mercado Pago (test credentials)
# Access token secreta (somente backend)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public key (opcional neste fluxo atual)
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL pública do app (usada para retorno do checkout e webhook)
APP_BASE_URL=https://menfisburguer.vercel.app
